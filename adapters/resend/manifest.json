      "endpoint": "/audiences/{audience_id}/contacts",
      "configSchema": {
        "type": "object",
        "required": ["audience_id", "email"],
        "properties": {
          "audience_id": {
            "type": "string",
            "description": "The ID of the audience"
          },
          "email": {
            "type": "string",
            "description": "Contact email address"
          },
          "first_name": {
            "type": "string",
            "description": "Contact first name"
          },
          "last_name": {
            "type": "string",
            "description": "Contact last name"
          },
          "unsubscribed": {
            "type": "boolean",
            "description": "Whether the contact is unsubscribed"
          }
        }
      },
      "responseSchema": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "object": { "type": "string" }
        }
      }
    },
    {
      "id": "list_contacts",
      "name": "List Contacts",
      "description": "List all contacts in an audience",
      "category": "contacts",
      "method": "GET",
      "endpoint": "/audiences/{audience_id}/contacts",
      "configSchema": {
        "type": "object",
        "required": ["audience_id"],
        "properties": {
          "audience_id": {
            "type": "string",
