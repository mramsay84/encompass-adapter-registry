{
  "actions": [
    {
      "id": "send_email",
      "name": "Send Email",
      "description": "Send a transactional email with HTML and/or plain text content",
      "category": "emails",
      "method": "POST",
      "endpoint": "/emails",
      "configSchema": {
        "type": "object",
        "required": ["to", "subject"],
        "properties": {
          "to": {
            "type": ["string", "array"],
            "description": "Recipient email address(es)"
          },
          "from": {
            "type": "string",
            "description": "Sender email (must be from a verified domain)"
          },
          "subject": {
            "type": "string",
            "description": "Email subject line"
          },
          "html": {
            "type": "string",
            "description": "HTML content of the email"
          },
          "text": {
            "type": "string",
            "description": "Plain text content of the email"
          },
          "cc": {
            "type": ["string", "array"],
            "description": "CC recipient(s)"
          },
          "bcc": {
            "type": ["string", "array"],
            "description": "BCC recipient(s)"
          },
          "reply_to": {
            "type": ["string", "array"],
            "description": "Reply-to email address(es)"
          },
          "headers": {
            "type": "object",
            "description": "Custom email headers"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "value": { "type": "string" }
              }
            },
            "description": "Tags for categorization and analytics"
          },
          "scheduled_at": {
            "type": "string",
            "description": "ISO 8601 datetime for scheduled delivery"
          }
        }
      },
      "responseSchema": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Email ID" }
        }
      }
    },
    {
      "id": "send_batch_emails",
      "name": "Send Batch Emails",
      "description": "Send up to 100 emails in a single API call",
      "category": "emails",
      "method": "POST",
      "endpoint": "/emails/batch",
      "configSchema": {
        "type": "object",
        "required": ["emails"],
        "properties": {
          "emails": {
            "type": "array",
            "description": "Array of email objects (max 100), each with to, from, subject, html/text",
            "items": {
              "type": "object",
              "required": ["to", "from", "subject"],
              "properties": {
                "to": { "type": ["string", "array"] },
                "from": { "type": "string" },
                "subject": { "type": "string" },
                "html": { "type": "string" },
                "text": { "type": "string" },
                "cc": { "type": ["string", "array"] },
                "bcc": { "type": ["string", "array"] },
                "reply_to": { "type": ["string", "array"] },
                "headers": { "type": "object" },
                "tags": { "type": "array" }
              }
            }
          }
        }
      },
      "responseSchema": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string" }
              }
            }
          }
        }
      }
    },
    {
      "id": "get_email",
      "name": "Get Email",
      "description": "Retrieve details and status of a sent email by ID",
      "category": "emails",
      "method": "GET",
      "endpoint": "/emails/{email_id}",
      "configSchema": {
        "type": "object",
        "required": ["email_id"],
        "properties": {
          "email_id": {
            "type": "string",
            "description": "The ID of the email to retrieve"
          }
        }
      },
      "responseSchema": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "from": { "type": "string" },
          "to": { "type": "array" },
          "subject": { "type": "string" },
          "created_at": { "type": "string" },
          "last_event": { "type": "string" }
        }
      }
    },
    {
      "id": "cancel_email",
      "name": "Cancel Scheduled Email",
      "description": "Cancel a scheduled email that has not yet been sent",
      "category": "emails",
      "method": "POST",
      "endpoint": "/emails/{email_id}/cancel",
      "configSchema": {
        "type": "object",
        "required": ["email_id"],
        "properties": {
          "email_id": {
            "type": "string",
            "description": "The ID of the scheduled email to cancel"
          }
        }
      },
      "responseSchema": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "object": { "type": "string" }
        }
      }
    },
    {
      "id": "create_domain",
      "name": "Create Domain",
      "description": "Add a new sending domain to your Resend account",
      "category": "domains",
      "method": "POST",
      "endpoint": "/domains",
      "configSchema": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "description": "The domain name (e.g., yourdomain.com)"
          },
          "region": {
            "type": "string",
            "enum": ["us-east-1", "eu-west-1", "sa-east-1"],
            "description": "Region for the domain"
          }
        }
      },
      "responseSchema": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "status": { "type": "string" },
          "records": { "type": "array" }
        }
      }
    },
    {
      "id": "list_domains",
      "name": "List Domains",
      "description": "Retrieve a list of all verified and pending domains",
