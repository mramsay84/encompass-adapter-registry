      "payloadSchema": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "const": "email.clicked" },
          "created_at": { "type": "string" },
          "data": {
            "type": "object",
            "properties": {
              "email_id": { "type": "string" },
