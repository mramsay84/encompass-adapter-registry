  "triggers": [
    {
      "id": "email_sent",
      "name": "Email Sent",
      "event": "email.sent",
      "description": "Triggered when an email is successfully sent to the recipient's mail server",
      "category": "Email Delivery",
      "payloadSchema": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "const": "email.sent" },
          "created_at": { "type": "string" },
          "data": {
            "type": "object",
            "properties": {
              "email_id": { "type": "string" },
              "from": { "type": "string" },
