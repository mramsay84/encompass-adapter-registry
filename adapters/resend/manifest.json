          },
          "permission": {
            "type": "string",
            "enum": ["full_access", "sending_access"],
            "description": "Permission level for the key"
          },
          "domain_id": {
            "type": "string",
            "description": "Restrict the key to a specific domain"
          }
        }
      },
      "responseSchema": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "token": { "type": "string" }
        }
      }
    },
    {
      "id": "list_api_keys",
