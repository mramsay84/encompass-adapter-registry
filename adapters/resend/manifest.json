      "description": "Remove a contact from an audience",
      "category": "contacts",
      "method": "DELETE",
      "endpoint": "/audiences/{audience_id}/contacts/{contact_id}",
      "configSchema": {
        "type": "object",
        "required": ["audience_id", "contact_id"],
        "properties": {
          "audience_id": {
            "type": "string",
            "description": "The ID of the audience"
          },
          "contact_id": {
            "type": "string",
            "description": "The ID of the contact to delete"
          }
        }
      },
      "responseSchema": {
        "type": "object",
        "properties": {
          "object": { "type": "string" },
          "id": { "type": "string" },
          "deleted": { "type": "boolean" }
