      "method": "GET",
      "endpoint": "/domains",
      "configSchema": {
        "type": "object",
        "properties": {}
      },
      "responseSchema": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "name": { "type": "string" },
                "status": { "type": "string" },
                "region": { "type": "string" },
                "created_at": { "type": "string" }
              }
            }
          }
        }
      }
    },
    {
      "id": "get_domain",
      "name": "Get Domain",
      "description": "Retrieve details and DNS records for a specific domain",
      "category": "domains",
      "method": "GET",
      "endpoint": "/domains/{domain_id}",
      "configSchema": {
        "type": "object",
        "required": ["domain_id"],
        "properties": {
          "domain_id": {
            "type": "string",
            "description": "The ID of the domain to retrieve"
          }
        }
      },
      "responseSchema": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "status": { "type": "string" },
          "region": { "type": "string" },
          "records": { "type": "array" }
        }
      }
    },
    {
      "id": "verify_domain",
      "name": "Verify Domain",
      "description": "Trigger DNS verification for a domain",
      "category": "domains",
      "method": "POST",
      "endpoint": "/domains/{domain_id}/verify",
      "configSchema": {
        "type": "object",
        "required": ["domain_id"],
        "properties": {
          "domain_id": {
            "type": "string",
            "description": "The ID of the domain to verify"
          }
        }
      },
      "responseSchema": {
        "type": "object",
        "properties": {
          "object": { "type": "string" }
        }
      }
    },
    {
      "id": "delete_domain",
      "name": "Delete Domain",
      "description": "Remove a domain from your Resend account",
      "category": "domains",
      "method": "DELETE",
      "endpoint": "/domains/{domain_id}",
      "configSchema": {
        "type": "object",
        "required": ["domain_id"],
        "properties": {
          "domain_id": {
            "type": "string",
            "description": "The ID of the domain to delete"
          }
        }
      },
      "responseSchema": {
        "type": "object",
        "properties": {
          "object": { "type": "string" },
          "id": { "type": "string" },
          "deleted": { "type": "boolean" }
        }
      }
    },
    {
      "id": "create_api_key",
      "name": "Create API Key",
      "description": "Create a new API key with specified permissions",
      "category": "api-keys",
      "method": "POST",
