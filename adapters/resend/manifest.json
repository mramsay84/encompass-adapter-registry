                "first_name": { "type": "string" },
                "last_name": { "type": "string" },
                "unsubscribed": { "type": "boolean" },
                "created_at": { "type": "string" }
              }
            }
          }
        }
      }
    },
    {
      "id": "get_contact",
      "name": "Get Contact",
      "description": "Retrieve details of a specific contact",
      "category": "contacts",
      "method": "GET",
      "endpoint": "/audiences/{audience_id}/contacts/{contact_id}",
      "configSchema": {
        "type": "object",
        "required": ["audience_id", "contact_id"],
        "properties": {
          "audience_id": {
            "type": "string",
            "description": "The ID of the audience"
          },
          "contact_id": {
            "type": "string",
            "description": "The ID of the contact"
          }
        }
      },
      "responseSchema": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "email": { "type": "string" },
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "unsubscribed": { "type": "boolean" },
          "created_at": { "type": "string" }
        }
      }
    },
    {
      "id": "update_contact",
      "name": "Update Contact",
      "description": "Update a contact's details in an audience",
      "category": "contacts",
      "method": "PATCH",
      "endpoint": "/audiences/{audience_id}/contacts/{contact_id}",
      "configSchema": {
        "type": "object",
        "required": ["audience_id", "contact_id"],
        "properties": {
          "audience_id": {
            "type": "string",
            "description": "The ID of the audience"
          },
          "contact_id": {
            "type": "string",
            "description": "The ID of the contact"
          },
          "first_name": {
            "type": "string",
            "description": "Updated first name"
          },
          "last_name": {
            "type": "string",
            "description": "Updated last name"
          },
          "unsubscribed": {
            "type": "boolean",
            "description": "Updated unsubscribe status"
          }
        }
      },
      "responseSchema": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "object": { "type": "string" }
        }
      }
    },
