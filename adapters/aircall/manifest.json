      "method": "GET",
      "endpoint": "/contacts/{id}",
      "configSchema": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "integer", "description": "Contact ID" }
        }
      }
    },
    {
      "id": "search_contacts",
      "name": "Search Contacts",
      "description": "Search contacts by phone number, email, or name",
      "category": "Contacts",
      "method": "GET",
      "endpoint": "/contacts/search",
      "configSchema": {
        "type": "object",
        "properties": {
          "phone_number": { "type": "string", "description": "Phone number to search" },
          "email": { "type": "string", "description": "Email to search" },
          "per_page": { "type": "integer", "minimum": 1, "maximum": 50 },
          "page": { "type": "integer", "minimum": 1 }
        }
      }
    },
    {
      "id": "create_contact",
      "name": "Create Contact",
      "description": "Create a new contact in the Aircall directory",
      "category": "Contacts",
      "method": "POST",
      "endpoint": "/contacts",
      "configSchema": {
        "type": "object",
        "required": ["phone_numbers"],
        "properties": {
          "first_name": { "type": "string", "description": "Contact first name" },
          "last_name": { "type": "string", "description": "Contact last name" },
          "company_name": { "type": "string", "description": "Company name" },
          "phone_numbers": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "label": { "type": "string" },
                "value": { "type": "string" }
              }
            },
            "description": "Phone numbers"
          },
          "emails": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "label": { "type": "string" },
                "value": { "type": "string" }
              }
            },
            "description": "Email addresses"
          }
        }
      }
    },
    {
      "id": "update_contact",
      "name": "Update Contact",
      "description": "Update an existing contact",
      "category": "Contacts",
      "method": "PUT",
      "endpoint": "/contacts/{id}",
      "configSchema": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "integer", "description": "Contact ID" },
          "first_name": { "type": "string" },
          "last_name": { "type": "string" },
          "company_name": { "type": "string" },
          "phone_numbers": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "label": { "type": "string" },
                "value": { "type": "string" }
              }
            }
          },
          "emails": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "label": { "type": "string" },
                "value": { "type": "string" }
              }
            }
          }
        }
      }
    },
    {
      "id": "delete_contact",
      "name": "Delete Contact",
      "description": "Delete a contact from the Aircall directory",
      "category": "Contacts",
      "method": "DELETE",
      "endpoint": "/contacts/{id}",
      "configSchema": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "integer", "description": "Contact ID" }
        }
      }
    },
    {
      "id": "list_numbers",
