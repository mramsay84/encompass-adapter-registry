    },
    {
      "id": "get_number",
      "name": "Get Number",
      "description": "Get details of a specific phone number",
      "category": "Numbers",
      "method": "GET",
      "endpoint": "/numbers/{id}",
      "configSchema": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "integer", "description": "Number ID" }
        }
      }
    },
    {
      "id": "send_message",
      "name": "Send Message",
      "description": "Send an SMS or text message via Aircall",
      "category": "Messaging",
      "method": "POST",
      "endpoint": "/numbers/{number_id}/messages",
      "configSchema": {
        "type": "object",
        "required": ["number_id", "to", "body"],
        "properties": {
          "number_id": { "type": "integer", "description": "Aircall number ID to send from" },
          "to": { "type": "string", "description": "Recipient phone number (E.164 format)" },
          "body": { "type": "string", "description": "Message content" }
        }
      }
    },
    {
      "id": "list_tags",
      "name": "List Tags",
      "description": "List all available tags",
      "category": "Tags",
      "method": "GET",
      "endpoint": "/tags",
      "configSchema": {
        "type": "object",
        "properties": {
          "per_page": { "type": "integer", "minimum": 1, "maximum": 50 },
          "page": { "type": "integer", "minimum": 1 }
        }
      }
    },
    {
      "id": "create_tag",
      "name": "Create Tag",
      "description": "Create a new tag for categorizing calls",
      "category": "Tags",
      "method": "POST",
      "endpoint": "/tags",
      "configSchema": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "description": "Tag name" },
          "color": { "type": "string", "description": "Tag color (hex)" }
        }
      }
    }
  ],
  "triggers": [
    {
      "id": "call_created",
      "name": "Call Created",
      "description": "Triggered when a new call is initiated (inbound or outbound)",
      "event": "call.created",
      "category": "Calls"
    },
    {
      "id": "call_answered",
      "name": "Call Answered",
      "description": "Triggered when a call is answered by an agent",
      "event": "call.answered",
      "category": "Calls"
    },
    {
      "id": "call_ended",
      "name": "Call Ended",
