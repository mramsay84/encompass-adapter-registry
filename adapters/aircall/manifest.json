{
  "actions": [
    {
      "id": "list_calls",
      "name": "List Calls",
      "description": "List recent calls with optional date and direction filters",
      "category": "Calls",
      "method": "GET",
      "endpoint": "/calls",
      "configSchema": {
        "type": "object",
        "properties": {
          "from": { "type": "string", "format": "date-time", "description": "Filter calls from this date (ISO 8601)" },
          "to": { "type": "string", "format": "date-time", "description": "Filter calls to this date (ISO 8601)" },
          "direction": { "type": "string", "enum": ["inbound", "outbound"], "description": "Filter by call direction" },
          "per_page": { "type": "integer", "minimum": 1, "maximum": 50, "description": "Results per page (max 50)" },
          "page": { "type": "integer", "minimum": 1, "description": "Page number" }
        }
      }
    },
    {
      "id": "get_call",
      "name": "Get Call",
      "description": "Get detailed information about a specific call including recording URL",
      "category": "Calls",
      "method": "GET",
      "endpoint": "/calls/{id}",
      "configSchema": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "integer", "description": "Call ID" }
        }
      }
    },
    {
      "id": "search_calls",
      "name": "Search Calls",
      "description": "Search calls by phone number, user, or other criteria",
      "category": "Calls",
      "method": "GET",
      "endpoint": "/calls/search",
      "configSchema": {
        "type": "object",
        "properties": {
          "phone_number": { "type": "string", "description": "Phone number to search (E.164 format)" },
          "from": { "type": "string", "format": "date-time", "description": "Start date" },
          "to": { "type": "string", "format": "date-time", "description": "End date" },
          "direction": { "type": "string", "enum": ["inbound", "outbound"] },
          "per_page": { "type": "integer", "minimum": 1, "maximum": 50 },
          "page": { "type": "integer", "minimum": 1 }
        }
      }
    },
    {
      "id": "transfer_call",
      "name": "Transfer Call",
      "description": "Transfer an active call to another user or number",
      "category": "Calls",
      "method": "POST",
      "endpoint": "/calls/{id}/transfers",
      "configSchema": {
        "type": "object",
        "required": ["id", "user_id"],
        "properties": {
          "id": { "type": "integer", "description": "Call ID" },
          "user_id": { "type": "integer", "description": "User ID to transfer to" }
        }
      }
    },
    {
      "id": "comment_call",
      "name": "Comment on Call",
      "description": "Add a comment or note to a call",
      "category": "Calls",
      "method": "POST",
      "endpoint": "/calls/{id}/comments",
      "configSchema": {
        "type": "object",
        "required": ["id", "content"],
        "properties": {
          "id": { "type": "integer", "description": "Call ID" },
          "content": { "type": "string", "description": "Comment text" }
        }
      }
    },
    {
      "id": "tag_call",
      "name": "Tag Call",
      "description": "Add a tag to a call for categorization",
      "category": "Calls",
      "method": "POST",
      "endpoint": "/calls/{id}/tags",
      "configSchema": {
        "type": "object",
        "required": ["id", "tag_id"],
        "properties": {
          "id": { "type": "integer", "description": "Call ID" },
          "tag_id": { "type": "integer", "description": "Tag ID to apply" }
        }
      }
    },
    {
      "id": "archive_call",
      "name": "Archive Call",
      "description": "Archive a call to mark it as processed",
      "category": "Calls",
      "method": "PUT",
      "endpoint": "/calls/{id}/archive",
      "configSchema": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "integer", "description": "Call ID" }
        }
      }
    },
    {
      "id": "list_users",
      "name": "List Users",
      "description": "List all users (agents) in the Aircall account",
      "category": "Users",
      "method": "GET",
      "endpoint": "/users",
      "configSchema": {
        "type": "object",
        "properties": {
          "per_page": { "type": "integer", "minimum": 1, "maximum": 50 },
          "page": { "type": "integer", "minimum": 1 }
        }
      }
    },
    {
      "id": "get_user",
      "name": "Get User",
      "description": "Get details of a specific user",
      "category": "Users",
      "method": "GET",
      "endpoint": "/users/{id}",
      "configSchema": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "integer", "description": "User ID" }
        }
      }
    },
    {
      "id": "dial_number",
      "name": "Dial Number",
      "description": "Initiate an outbound call from a user to a phone number",
      "category": "Users",
      "method": "POST",
      "endpoint": "/users/{user_id}/dial",
      "configSchema": {
        "type": "object",
        "required": ["user_id", "phone_number", "number_id"],
        "properties": {
          "user_id": { "type": "integer", "description": "User ID to make the call" },
          "phone_number": { "type": "string", "description": "Phone number to dial (E.164 format)" },
          "number_id": { "type": "integer", "description": "Aircall number ID to use as caller ID" }
        }
      }
    },
    {
      "id": "list_teams",
      "name": "List Teams",
      "description": "List all teams in the account",
      "category": "Teams",
      "method": "GET",
      "endpoint": "/teams",
      "configSchema": {
        "type": "object",
        "properties": {
          "per_page": { "type": "integer", "minimum": 1, "maximum": 50 },
          "page": { "type": "integer", "minimum": 1 }
        }
      }
    },
    {
      "id": "get_team",
      "name": "Get Team",
      "description": "Get details of a specific team",
      "category": "Teams",
      "method": "GET",
      "endpoint": "/teams/{id}",
      "configSchema": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "integer", "description": "Team ID" }
        }
      }
    },
    {
      "id": "create_team",
      "name": "Create Team",
      "description": "Create a new team for call routing",
      "category": "Teams",
      "method": "POST",
      "endpoint": "/teams",
      "configSchema": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "description": "Team name" }
        }
      }
    },
    {
      "id": "add_user_to_team",
      "name": "Add User to Team",
      "description": "Add a user to a team",
      "category": "Teams",
      "method": "POST",
      "endpoint": "/teams/{team_id}/users/{user_id}",
      "configSchema": {
        "type": "object",
        "required": ["team_id", "user_id"],
        "properties": {
          "team_id": { "type": "integer", "description": "Team ID" },
          "user_id": { "type": "integer", "description": "User ID to add" }
        }
      }
    },
    {
      "id": "remove_user_from_team",
      "name": "Remove User from Team",
      "description": "Remove a user from a team",
      "category": "Teams",
      "method": "DELETE",
      "endpoint": "/teams/{team_id}/users/{user_id}",
      "configSchema": {
        "type": "object",
        "required": ["team_id", "user_id"],
        "properties": {
          "team_id": { "type": "integer", "description": "Team ID" },
          "user_id": { "type": "integer", "description": "User ID to remove" }
        }
      }
    },
    {
      "id": "list_contacts",
      "name": "List Contacts",
      "description": "List all contacts in the Aircall directory",
      "category": "Contacts",
      "method": "GET",
      "endpoint": "/contacts",
      "configSchema": {
        "type": "object",
        "properties": {
          "per_page": { "type": "integer", "minimum": 1, "maximum": 50 },
